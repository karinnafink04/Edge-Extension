{
  "manifest_version": 3,
  "name": "Timestamp Inserter",
  "version": "1.0",

  "permissions": ["storage", "activeTab", "scripting", "commands"],

  "commands": {
    "insert_timestamp_initials": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Insert timestamp and initials"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
